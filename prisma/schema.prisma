// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
    AGENT
    RESPONSABLE
    GESTIONNAIRE
}

enum EtatDossier {
    RECU
    EN_COURS
    EN_ATTENTE
    EN_ATTENTE_VALIDATION
    VALIDE
    CLOTURE
    BLOQUE
}

enum TypeElement {
    NOTE
    OBSERVATION
    PIECE
}

// ─── Auth.js v5 adapter models ────────────────────────────────────────────────
// Story 1.3 configurera PrismaAdapter avec { userModel: "Utilisateur" }

model Account {
    id                       String      @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    refresh_token_expires_in Int?
    utilisateur              Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String      @id @default(cuid())
    sessionToken String      @unique
    userId       String
    expires      DateTime
    utilisateur  Utilisateur @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Modèle utilisateur (remplace User T3 — Story 1.2) ───────────────────────

model Utilisateur {
    id            String               @id @default(cuid())
    name          String?
    email         String               @unique
    emailVerified DateTime?
    image         String?
    role          Role                 @default(AGENT)
    password      String?
    // Auth.js relations
    accounts      Account[]
    sessions      Session[]
    // Relations métier
    dossiers             Dossier[]
    transitions          Transition[]
    elementsInstruction  ElementInstruction[]
}

// ─── Modèles métier ───────────────────────────────────────────────────────────

model Dossier {
    id                  String               @id @default(cuid())
    reference           String               @unique
    intitule            String
    motif               String
    demandeur           String
    referenceExterne    String?
    etatCourant         EtatDossier
    etatAvantSuspension EtatDossier?
    agentId             String?
    agent               Utilisateur?         @relation(fields: [agentId], references: [id])
    dateReception       DateTime
    updatedAt           DateTime             @updatedAt
    createdAt           DateTime             @default(now())
    transitions         Transition[]
    elements            ElementInstruction[]
}

model Transition {
    id         String      @id @default(cuid())
    dossierId  String
    etatSource EtatDossier
    etatCible  EtatDossier
    auteurId   String
    motif      String?
    createdAt  DateTime    @default(now())
    dossier    Dossier     @relation(fields: [dossierId], references: [id])
    auteur     Utilisateur @relation(fields: [auteurId], references: [id])
}

model ElementInstruction {
    id        String      @id @default(cuid())
    dossierId String
    type      TypeElement
    contenu   String
    auteurId  String
    createdAt DateTime    @default(now())
    dossier   Dossier     @relation(fields: [dossierId], references: [id])
    auteur    Utilisateur @relation(fields: [auteurId], references: [id])
}
